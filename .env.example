# Freelancer Credentials
FREELANCER_EMAIL=your_email@gmail.com
FREELANCER_PASSWORD=your_password

# Bidding Configuration
BID_AMOUNT=50
MIN_BID_AMOUNT=10
MAX_BID_AMOUNT=500

# Skills and Keywords Filter
SKILLS=nodejs,javascript,react,express,mongodb
KEYWORDS=web development,full stack,api,backend
EXCLUDED_KEYWORDS=urgent,asap,php,python

# Budget Filter
MIN_PROJECT_BUDGET=100
MAX_PROJECT_BUDGET=5000

# ChatGPT Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_TEMPERATURE=0.7

# AI Server Configuration
AI_SERVER_PORT=3001
AI_SERVER_HOST=localhost

# Bot Configuration
SEARCH_KEYWORDS=nodejs,javascript,web development
MAX_PROJECTS_TO_BID=10
DELAY_BETWEEN_BIDS=3000
HEADLESS_MODE=true

# Logging
DEBUG=true
